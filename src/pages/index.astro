---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = await getCollection('projects');
// Sort by date descending
projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
	<main>
		<header class="hero">
			<h1>Ron Bulischeck</h1>
			<p class="bio">
				Senior Process Engineer specializing in **industrial automation**, **standardization**, and **data-driven optimization**. 
				I build operational systems designed for scale, reliability, and measurable efficiency.
			</p>
			<div class="contact-links">
				<a href="mailto:rbulischeck@gmail.com">Email</a>
				<a href="https://github.com/rdyb33" target="_blank">GitHub</a>
				<span>Union, MO</span>
			</div>
		</header>

		<section class="projects-section">
			<h2>Technical Projects</h2>
			<div class="projects-grid">
				{projects.map((project) => (
					<ProjectCard project={project} />
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 4rem 2rem;
		font-family: system-ui, -apple-system, sans-serif;
		color: #111827;
	}

	.hero {
		margin-bottom: 5rem;
	}

	h1 {
		font-size: 3rem;
		font-weight: 800;
		letter-spacing: -0.025em;
		margin: 0 0 1.5rem 0;
	}

	.bio {
		font-size: 1.25rem;
		line-height: 1.6;
		color: #4b5563;
		max-width: 65ch;
		margin-bottom: 2rem;
	}

	.bio :global(strong) {
		color: #111827;
		font-weight: 600;
	}

	.contact-links {
		display: flex;
		gap: 1.5rem;
		font-size: 0.95rem;
		color: #6b7280;
	}

	.contact-links a {
		color: #2563eb;
		text-decoration: none;
		font-weight: 500;
	}

	.contact-links a:hover {
		text-decoration: underline;
	}

	.projects-section h2 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 2.5rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid #e5e7eb;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2rem;
	}

	@media (max-width: 640px) {
		main {
			padding: 2rem 1.5rem;
		}
		h1 {
			font-size: 2.5rem;
		}
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
