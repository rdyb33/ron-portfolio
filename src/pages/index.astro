---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
	<div class="blueprint-bg"></div>
	<main class="resume-container">
		<!-- Header / Contact Info -->
		<header class="resume-header">
			<div class="header-content">
				<h1>Ron D. <span class="accent-text">Bulischeck</span> III</h1>
				<div class="contact-info">
					<span class="info-item"><span class="label">LOC</span> Union, MO</span>
					<span class="info-item"><span class="label">TEL</span> <a href="tel:+16602383658">(660) 238-3658</a></span>
					<span class="info-item"><span class="label">EML</span> <a href="mailto:rbulischeck@gmail.com">rbulischeck@gmail.com</a></span>
					<span class="info-item web-only"><span class="label">GIT</span> <a href="https://github.com/rdyb33" target="_blank">github.com/rdyb33</a></span>
				</div>
			</div>
		</header>

		<div class="resume-grid">
			<!-- Main Column -->
			<div class="main-col">
				<!-- Executive Summary -->
				<section class="resume-section">
					<h2 class="section-title">Objective / Summary</h2>
					<p class="summary-text">
						Strategic professional focused on defining clear, measurable objectives for operational efficiency. Expert in **process optimization**, **data-driven decision-making**, and implementing best practices to achieve tangible improvements in key performance indicators. Over 10 years of experience in manufacturing and process engineering, currently managing automation strategy for Paulo Products.
					</p>
				</section>

				<!-- Professional Experience -->
				<section class="resume-section">
					<h2 class="section-title">Professional Experience</h2>
					
					<div class="experience-item">
						<div class="exp-header">
							<h3>Paulo Products (Aalberts)</h3>
							<span class="date-badge">2022 – Present</span>
						</div>
						<div class="exp-sub">St. Louis, MO | Process Engineer</div>
						<ul>
							<li><strong>Automation Project Lead:</strong> Managing CC17 Automated Cell integration (Robotics, Gantry, Vision). <em>Result: Projected reduction of 6 FTEs.</em></li>
							<li><strong>Multi-Site Standardization:</strong> Standardized work instructions and parameters across international facilities.</li>
							<li><strong>Cost Engineering:</strong> ROI & feasibility analysis for major capital investments.</li>
						</ul>
					</div>

					<div class="experience-item">
						<div class="exp-header">
							<h3>Henniges Automotive</h3>
							<span class="date-badge">2019 – 2022</span>
						</div>
						<div class="exp-sub">New Haven, MO | Engineering Program Manager</div>
						<ul>
							<li><strong>Capital Project Execution:</strong> Directed $3.6M in upgrades. <em>Result: Achieved $1.6M in annual labor savings.</em></li>
						</ul>
					</div>

					<div class="experience-item">
						<div class="exp-header">
							<h3>Shure Manufacturing Corp</h3>
							<span class="date-badge">2015 – 2019</span>
						</div>
						<div class="exp-sub">Washington, MO | Design Engineer</div>
						<ul>
							<li><strong>Product Development:</strong> Developed RFID-based tool tracking system. <em>Result: Generated $1M/year in new revenue.</em></li>
						</ul>
					</div>
				</section>
			</div>

			<!-- Side Column -->
			<aside class="side-col">
				<section class="resume-section">
					<h2 class="section-title">Technical Skills</h2>
					<div class="skill-group">
						<span class="skill-label">Automation</span>
						<div class="skill-tags">
							<span>Robotics</span> <span>Vision</span> <span>PLC</span> <span>Python</span> <span>AI</span>
						</div>
					</div>
					<div class="skill-group">
						<span class="skill-label">Methodology</span>
						<div class="skill-tags">
							<span>Lean</span> <span>Six Sigma</span> <span>DMAIC</span> <span>VSM</span>
						</div>
					</div>
					<div class="skill-group">
						<span class="skill-label">Tools</span>
						<div class="skill-tags">
							<span>CAD</span> <span>ERP</span> <span>CLI</span> <span>Wrangler</span>
						</div>
					</div>
				</section>

				<section class="resume-section">
					<h2 class="section-title">Education</h2>
					<div class="edu-item">
						<strong>Missouri S&T</strong>
						<span>B.S. Mechanical Engineering</span>
						<small>Emphasis in Design Analysis</small>
					</div>
				</section>
			</aside>
		</div>

		<!-- Quote -->
		<blockquote class="personal-statement">
			"I focus on building operational systems that can not break. My approach is to standardize the chaos and lead by example."
		</blockquote>

		<!-- Technical Portfolio (Web Only) -->
		<section class="resume-section print-hide">
			<h2 class="section-title centered">Technical Project Documentation</h2>
			<div class="projects-grid">
				{projects.map((project) => (
					<ProjectCard project={project} />
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	:root {
		--primary: #0f172a;
		--accent: #2563eb;
		--accent-soft: #dbeafe;
		--text-main: #334155;
		--text-bold: #0f172a;
		--border: #e2e8f0;
	}

	.blueprint-bg {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			linear-gradient(var(--border) 1px, transparent 1px),
			linear-gradient(90deg, var(--border) 1px, transparent 1px);
		background-size: 40px 40px;
		opacity: 0.15;
		z-index: -1;
		pointer-events: none;
	}

	.resume-container {
		max-width: 1100px;
		margin: 2rem auto;
		background: #ffffff;
		box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
		border-radius: 8px;
		padding: 4rem;
		border-top: 8px solid var(--primary);
	}

	.resume-header {
		margin-bottom: 3rem;
	}

	h1 {
		font-size: 3.5rem;
		font-weight: 900;
		margin: 0 0 1rem 0;
		color: var(--primary);
		letter-spacing: -0.025em;
		line-height: 1;
	}

	.accent-text { color: var(--accent); }

	.contact-info {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
		font-size: 0.85rem;
	}

	.label { color: var(--accent); font-weight: bold; margin-right: 0.4rem; }
	.contact-info a { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; transition: 0.2s; }
	.contact-info a:hover { border-color: var(--accent); color: var(--accent); }

	.resume-grid {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: 4rem;
	}

	.section-title {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		font-weight: 800;
		margin-bottom: 1.5rem;
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.section-title::after {
		content: "";
		flex-grow: 1;
		height: 1px;
		background: var(--border);
	}

	.section-title.centered { justify-content: center; }
	.section-title.centered::before { content: ""; flex-grow: 1; height: 1px; background: var(--border); }

	.summary-text { font-size: 1.1rem; line-height: 1.7; color: var(--text-main); margin-bottom: 2.5rem; }
	.summary-text strong { color: var(--text-bold); }

	.experience-item { margin-bottom: 2.5rem; }
	.exp-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.25rem; }
	.exp-header h3 { margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-bold); }
	.date-badge { background: var(--accent-soft); color: var(--accent); padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.8rem; font-weight: 700; }
	.exp-sub { font-size: 0.95rem; color: var(--text-main); font-weight: 500; margin-bottom: 0.75rem; }

	ul { padding-left: 1.25rem; margin: 0; }
	li { margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--text-main); }
	li strong { color: var(--text-bold); }

	.skill-group { margin-bottom: 1.5rem; }
	.skill-label { display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: #64748b; margin-bottom: 0.5rem; }
	.skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
	.skill-tags span { background: #f8fafc; border: 1px solid var(--border); padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem; font-weight: 500; }

	.edu-item { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.95rem; }
	.edu-item small { color: #64748b; }

	.personal-statement {
		background: #f8fafc;
		border: 1px solid var(--border);
		padding: 2rem;
		border-radius: 8px;
		font-style: italic;
		color: var(--text-main);
		font-size: 1.1rem;
		text-align: center;
		margin: 4rem 0;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2.5rem;
		margin-top: 2rem;
	}

	@media print {
		.blueprint-bg { display: none; }
		.resume-container { 
			box-shadow: none; 
			padding: 0; 
			margin: 0; 
			max-width: 100%;
			border-top: none;
		}
		.resume-grid { grid-template-columns: 1fr; gap: 1rem; }
		.side-col { order: -1; display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem; }
		.print-hide { display: none !important; }
		h1 { font-size: 2.5rem; }
		.resume-header { border-bottom: 2px solid var(--primary); padding-bottom: 1rem; }
		@page { margin: 0.5in; }
	}

	@media (max-width: 900px) {
		.resume-container { padding: 2rem; }
		.resume-grid { grid-template-columns: 1fr; }
		.side-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
		h1 { font-size: 2.5rem; }
	}

	@media (max-width: 600px) {
		.side-col { grid-template-columns: 1fr; }
	}
</style>
